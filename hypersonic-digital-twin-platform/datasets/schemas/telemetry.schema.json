{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AETHER-TWIN Telemetry Tick",
  "type": "object",
  "required": ["simulation_id", "time_s", "aircraft", "thermal", "cooling", "risk"],
  "properties": {
    "simulation_id": { "type": "string" },
    "time_s": { "type": "number" },
    "aircraft": {
      "type": "object",
      "properties": {
        "mach": { "type": "number" },
        "altitude_m": { "type": "number" }
      }
    },
    "thermal": {
      "type": "object",
      "properties": {
        "heat_flux_w_m2": { "type": "number" },
        "max_surface_temp_k": { "type": "number" },
        "thermal_margin": { "type": "number" }
      }
    },
    "cooling": {
      "type": "object",
      "properties": {
        "efficiency": { "type": "number" },
        "mass_flow_kg_s": { "type": "number" }
      }
    },
    "risk": {
      "type": "object",
      "properties": {
        "level": { "type": "string" },
        "score": { "type": "number" }
      }
    }
  }
}

